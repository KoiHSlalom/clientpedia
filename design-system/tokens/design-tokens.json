        "h4": {"size": "{fontSizes.3xl}", "weight": "{type.weight.semibold}", "leading": "{type.leading.snug}"},
        "h5": {"size": "{fontSizes.2xl}", "weight": "{type.weight.medium}", "leading": "{type.leading.snug}"},
        "h6": {"size": "{fontSizes.xl}", "weight": "{type.weight.medium}", "leading": "{type.leading.snug}"}
      },
      "display": {
        "display-1": {"size": "{fontSizes.7xl}", "weight": "{type.weight.bold}", "leading": "{type.leading.tight}"},
        "display-2": {"size": "{fontSizes.8xl}", "weight": "{type.weight.bold}", "leading": "{type.leading.tight}"}
      },
      "caption": {"size": "{fontSizes.sm}", "weight": "{type.weight.regular}", "leading": "{type.leading.normal}"},
      "label": {"size": "{fontSizes.xs}", "weight": "{type.weight.medium}", "leading": "{type.leading.snug}"},
      "nav": {"size": "{fontSizes.base}", "weight": "{type.weight.medium}", "leading": "{type.leading.snug}"}
